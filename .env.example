# AWS Configuration
AWS_REGION=us-east-1

# SES Email Configuration
SES_FROM_EMAIL=noreply@adaptivefactory.net
DEMO_REQUEST_TO_EMAIL=pat@adaptivefactory.net

# S3 Storage Configuration
DEMO_REQUEST_S3_BUCKET=adaptivefactory-leads
DEMO_REQUEST_S3_KMS_KEY_ID=alias/ekas-s3

# HubSpot Integration
# Server-side: used by demo-request route handler to forward leads to HubSpot CRM
HUBSPOT_PORTAL_ID=246054670
# HubSpot form GUID for the "EKAS Demo Request — Server-Sync" form
HUBSPOT_FORM_GUID=b9d421ef-67a9-4613-99d2-9821f1fe2f96
# Client-side: used by tracking script in root layout. If unset, script does not load.
NEXT_PUBLIC_HUBSPOT_PORTAL_ID=246054670
# HUBSPOT_FORMS_API_KEY=  # only if using authenticated forms endpoint (rate-limit fallback)

# IMPORTANT: Do not commit actual .env file with real credentials
# Copy this file to .env.local for local development
# For production, set these in AWS Amplify Console > Environment Variables
